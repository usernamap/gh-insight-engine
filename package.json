{
  "name": "gh-insight-engine",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run openapi:validate && tsx watch src/server.ts",
    "start": "node dist/server.js",
    "start:prod": "npm run build:prod && npm run start",
    "build": "npm run clean && npm run openapi:validate && npm run typecheck && npx prisma generate && tsc --outDir dist && npm run openapi:build",
    "build:prod": "npm run lint && npm run test && npm run build && npm run optimize",
    "optimize": "echo 'Build optimized for production'",
    "test": "npm run test:ordered",
    "test:ordered": "npm run test:01 && npm run test:02 && npm run test:03 && npm run test:04 && npm run test:05 && npm run test:06 && npm run test:07",
    "test:01": "jest --runInBand tests/01-system.test.ts",
    "test:02": "jest --runInBand tests/02-authentication.test.ts",
    "test:03": "jest --runInBand tests/03-users.test.ts",
    "test:04": "jest --runInBand tests/04-repositories.test.ts",
    "test:05": "jest --runInBand tests/05-analytics.test.ts",
    "test:06": "jest --runInBand tests/06-insights.test.ts",
    "test:07": "jest --runInBand tests/07-integration.test.ts",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:e2e": "jest --testPathPattern=e2e --passWithNoTests",
    "test:api": "tsx tests/run-all-tests.ts",
    "test:system": "jest tests/01-system.test.ts --verbose",
    "test:auth": "jest tests/02-authentication.test.ts --verbose",
    "test:users": "jest tests/03-users.test.ts --verbose",
    "test:repos": "jest tests/04-repositories.test.ts --verbose",
    "test:analytics": "jest tests/05-analytics.test.ts --verbose",
    "test:insights": "jest tests/06-insights.test.ts --verbose",
    "test:integration": "jest tests/07-integration.test.ts --verbose",
    "test:openapi": "node -e \"const {openAPIValidator} = require('./tests/utils/OpenAPIValidator.ts'); openAPIValidator.generateCoverageReport();\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts --max-warnings 0",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.{ts,js,json}",
    "format:check": "prettier --check src/**/*.{ts,js,json}",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset --force",
    "postinstall": "npx prisma generate",
    "clean": "rm -rf dist coverage .nyc_output docs/index.html",
    "precommit": "npm run openapi:validate && npm run openapi:coverage && npm run lint && npm run typecheck",
    "prepare": "husky install",
    "health": "curl -f http://localhost:3000/api/health || exit 1",
    "logs": "tail -f app.log",
    "openapi:lint": "spectral lint openapi.yaml --format stylish",
    "openapi:lint:json": "spectral lint openapi.yaml --format json",
    "openapi:validate": "spectral lint openapi.yaml --format stylish --fail-severity error --fail-severity warn",
    "openapi:diff": "openapi-diff openapi.yaml openapi.yaml.backup",
    "openapi:diff:breaking": "openapi-diff openapi.yaml openapi.yaml.backup --fail-on-diff",
    "openapi:backup": "cp openapi.yaml openapi.yaml.backup",
    "openapi:serve": "npx @redocly/cli preview-docs openapi.yaml --port 8080",
    "openapi:build": "npx @redocly/cli build-docs openapi.yaml --output docs/index.html --theme.openapi.disableSearch=false",
    "openapi:check": "npm run openapi:validate && npm run openapi:coverage && npm run openapi:diff:breaking",
    "openapi:coverage": "node scripts/validate-api-coverage.js",
    "openapi:workflow": "npm run openapi:backup && npm run openapi:validate && npm run openapi:coverage && npm run openapi:diff && npm run openapi:build",
    "version:bump": "node scripts/version-bump.js",
    "release": "npm run version:bump && npm run openapi:workflow && git add . && git commit -m \"chore: release v$(node -p \"require('./package.json').version\")\" && git push origin main",
    "deploy": "npm run build:prod && npm run release"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@redocly/cli": "^1.34.5",
    "@stoplight/spectral-cli": "^6.15.0",
    "@stoplight/spectral-core": "^1.20.0",
    "@stoplight/spectral-formats": "^1.8.2",
    "@types/compression": "^1.8.1",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.0.15",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest": "^30.0.4",
    "mongodb-memory-server": "^10.1.4",
    "openapi-diff": "^0.23.7",
    "prettier": "^3.6.2",
    "redoc-cli": "^0.13.21",
    "supertest": "^7.1.3",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@octokit/auth-token": "^6.0.0",
    "@octokit/graphql": "^9.0.1",
    "@octokit/rest": "^22.0.0",
    "@prisma/client": "^6.12.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/uuid": "^10.0.0",
    "axios": "^1.10.0",
    "bcryptjs": "^3.0.2",
    "chalk": "^5.4.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "eslint-plugin-import": "^2.32.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "install": "^0.13.0",
    "joi": "^17.13.3",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.4",
    "morgan": "^1.10.1",
    "npm": "^11.4.2",
    "openai": "^5.10.1",
    "recast": "^0.23.11",
    "redoc-express": "^2.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.3",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^3.25.76"
  }
}
