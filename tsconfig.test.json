{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "esnext",
        "target": "ES2020",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "types": [
            "jest",
            "node"
        ],
        "baseUrl": "./",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@/config/*": [
                "./src/config/*"
            ],
            "@/controllers/*": [
                "./src/controllers/*"
            ],
            "@/middleware/*": [
                "./src/middleware/*"
            ],
            "@/models/*": [
                "./src/models/*"
            ],
            "@/routes/*": [
                "./src/routes/*"
            ],
            "@/services/*": [
                "./src/services/*"
            ],
            "@/types/*": [
                "./src/types/*"
            ],
            "@/utils/*": [
                "./src/utils/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "tests/**/*",
        "*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}