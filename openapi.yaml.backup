components:
  securitySchemes:
    BearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
      description: |
        Token JWT obtenu via l'endpoint `/auth/login`.
        
        **Format :** `Bearer <votre_token_jwt>`
        
        **Durée de vie :** 24 heures

  schemas:
    HealthResponse:
      type: object
      properties:
        status:
          type: string
          example: "healthy"
        service:
          type: string
          example: "GitHub Insight Engine API"
        version:
          type: string
          example: "1.0.0"
        timestamp:
          type: string
          format: date-time
        uptime:
          type: number
          example: 3600
        environment:
          type: string
          example: "development"

    PingResponse:
      type: object
      properties:
        message:
          type: string
          example: "pong"
        timestamp:
          type: string
          format: date-time

    LoginRequest:
      type: object
      required:
        - username
        - fullName
        - githubToken
      properties:
        username:
          type: string
          description: Nom d'utilisateur GitHub
          example: "octocat"
        fullName:
          type: string
          description: Nom complet de l'utilisateur
          example: "The Octocat"
        githubToken:
          type: string
          description: Token GitHub Classic avec permissions repo/user/read:org
          example: "ghp_xxxxxxxxxxxxxxxxxxxx"

    LoginResponse:
      type: object
      properties:
        message:
          type: string
          example: "Authentification réussie"
        user:
          $ref: '#/components/schemas/AuthenticatedUser'
        tokens:
          type: object
          properties:
            accessToken:
              type: string
              description: Token JWT pour les requêtes API
            tokenType:
              type: string
              example: "Bearer"
            expiresIn:
              type: string
              example: "24h"
        permissions:
          type: object
          properties:
            canAccessPrivateRepos:
              type: boolean
            canReadOrgs:
              type: boolean
            canReadUser:
              type: boolean
        timestamp:
          type: string
          format: date-time

    AuthenticatedUser:
      type: object
      properties:
        id:
          type: string
        username:
          type: string
        hasValidToken:
          type: boolean

    CollectionResponse:
      type: object
      properties:
        message:
          type: string
          example: "Collecte des données utilisateur réussie"
        status:
          type: string
          example: "completed"
        summary:
          type: object
          properties:
            username:
              type: string
            repositoriesCollected:
              type: integer
            organizationsScanned:
              type: integer
            dataFreshness:
              type: string
              example: "live"
        metadata:
          type: object
          properties:
            collectedAt:
              type: string
              format: date-time
            nextCollectionRecommended:
              type: string
              format: date-time
        timestamp:
          type: string
          format: date-time

    UserCompleteResponse:
      type: object
      properties:
        userProfile:
          $ref: '#/components/schemas/GitHubUserProfile'
        metadata:
          $ref: '#/components/schemas/DatasetMetadata'
        repositories:
          type: array
          items:
            $ref: '#/components/schemas/GitHubRepository'
        timestamp:
          type: string
          format: date-time

    RepositoriesCompleteResponse:
      type: object
      properties:
        repositories:
          type: array
          items:
            $ref: '#/components/schemas/GitHubRepository'
        analytics:
          $ref: '#/components/schemas/RepositoriesAnalytics'
        metadata:
          $ref: '#/components/schemas/CollectionMetadata'
        timestamp:
          type: string
          format: date-time

    GitHubUserProfile:
      type: object
      properties:
        login:
          type: string
        name:
          type: string
        email:
          type: string
        avatarUrl:
          type: string
        bio:
          type: string
        company:
          type: string
        location:
          type: string
        blog:
          type: string
        twitterUsername:
          type: string
        followers:
          type: integer
        following:
          type: integer
        publicRepos:
          type: integer
        publicGists:
          type: integer
        privateRepos:
          type: integer
        organizations:
          type: object
          properties:
            totalCount:
              type: integer
            nodes:
              type: array
              items:
                $ref: '#/components/schemas/GitHubOrganization'
        createdAt:
          type: string
          format: date-time
        updatedAt:
          type: string
          format: date-time

    GitHubOrganization:
      type: object
      properties:
        login:
          type: string
        name:
          type: string
        description:
          type: string
        avatarUrl:
          type: string

    GitHubRepository:
      type: object
      properties:
        nameWithOwner:
          type: string
        name:
          type: string
        description:
          type: string
        isPrivate:
          type: boolean
        isArchived:
          type: boolean
        isFork:
          type: boolean
        isTemplate:
          type: boolean
        stargazerCount:
          type: integer
        forkCount:
          type: integer
        watchersCount:
          type: integer
        primaryLanguage:
          type: string
        languages:
          $ref: '#/components/schemas/LanguageStats'
        topics:
          type: array
          items:
            type: string
        pushedAt:
          type: string
          format: date-time
        createdAt:
          type: string
          format: date-time
        homepageUrl:
          type: string
        size:
          type: integer
        defaultBranchRef:
          type: string
        license:
          $ref: '#/components/schemas/License'
        hasIssuesEnabled:
          type: boolean
        hasWikiEnabled:
          type: boolean
        hasPages:
          type: boolean
        commits:
          $ref: '#/components/schemas/CommitStats'
        releases:
          $ref: '#/components/schemas/ReleaseStats'
        issues:
          $ref: '#/components/schemas/IssueStats'
        pullRequests:
          $ref: '#/components/schemas/PullRequestStats'
        githubActions:
          $ref: '#/components/schemas/GitHubActions'
        security:
          $ref: '#/components/schemas/SecurityData'
        packages:
          $ref: '#/components/schemas/PackageData'
        branchProtection:
          $ref: '#/components/schemas/BranchProtectionData'
        community:
          $ref: '#/components/schemas/CommunityData'
        traffic:
          $ref: '#/components/schemas/TrafficData'
        owner:
          $ref: '#/components/schemas/RepositoryOwner'

    LanguageStats:
      type: object
      properties:
        totalSize:
          type: integer
        nodes:
          type: array
          items:
            type: object
            properties:
              name:
                type: string
              size:
                type: integer
              percentage:
                type: number

    License:
      type: object
      properties:
        name:
          type: string
        spdxId:
          type: string
        url:
          type: string

    CommitStats:
      type: object
      properties:
        totalCount:
          type: integer
        recent:
          type: array
          items:
            $ref: '#/components/schemas/Commit'

    Commit:
      type: object
      properties:
        oid:
          type: string
        message:
          type: string
        committedDate:
          type: string
          format: date-time
        author:
          $ref: '#/components/schemas/CommitAuthor'
        additions:
          type: integer
        deletions:
          type: integer
        changedFiles:
          type: integer

    CommitAuthor:
      type: object
      properties:
        name:
          type: string
        email:
          type: string
        login:
          type: string

    ReleaseStats:
      type: object
      properties:
        totalCount:
          type: integer
        latestRelease:
          $ref: '#/components/schemas/Release'

    Release:
      type: object
      properties:
        name:
          type: string
        tagName:
          type: string
        publishedAt:
          type: string
          format: date-time
        isLatest:
          type: boolean

    IssueStats:
      type: object
      properties:
        totalCount:
          type: integer
        openCount:
          type: integer
        closedCount:
          type: integer

    PullRequestStats:
      type: object
      properties:
        totalCount:
          type: integer
        openCount:
          type: integer
        closedCount:
          type: integer
        mergedCount:
          type: integer

    GitHubActions:
      type: object
      properties:
        workflowsCount:
          type: integer
        lastRunStatus:
          type: string
        workflows:
          type: array
          items:
            $ref: '#/components/schemas/Workflow'
        runs:
          $ref: '#/components/schemas/WorkflowRuns'

    Workflow:
      type: object
      properties:
        name:
          type: string
        path:
          type: string
        state:
          type: string
        createdAt:
          type: string
          format: date-time
        updatedAt:
          type: string
          format: date-time

    WorkflowRuns:
      type: object
      properties:
        totalCount:
          type: integer
        successful:
          type: integer
        failed:
          type: integer
        successRate:
          type: number

    SecurityData:
      type: object
      properties:
        dependabotAlerts:
          $ref: '#/components/schemas/AlertStats'
        secretScanning:
          $ref: '#/components/schemas/AlertStats'
        codeScanning:
          $ref: '#/components/schemas/AlertStats'
        hasSecurityPolicy:
          type: boolean
        hasVulnerabilityAlertsEnabled:
          type: boolean

    AlertStats:
      type: object
      properties:
        totalCount:
          type: integer
        open:
          type: integer
        fixed:
          type: integer
        dismissed:
          type: integer

    PackageData:
      type: object
      properties:
        totalCount:
          type: integer
        types:
          type: array
          items:
            type: string

    BranchProtectionData:
      type: object
      properties:
        rules:
          type: array
          items:
            $ref: '#/components/schemas/BranchProtectionRule'

    BranchProtectionRule:
      type: object
      properties:
        pattern:
          type: string
        requiresStatusChecks:
          type: boolean
        requiresCodeOwnerReviews:
          type: boolean
        dismissStaleReviews:
          type: boolean
        restrictsPushes:
          type: boolean
        requiredStatusChecks:
          type: array
          items:
            type: string

    CommunityData:
      type: object
      properties:
        healthPercentage:
          type: integer
        hasReadme:
          type: boolean
        hasLicense:
          type: boolean
        hasContributing:
          type: boolean
        hasCodeOfConduct:
          type: boolean
        hasIssueTemplate:
          type: boolean
        hasPullRequestTemplate:
          type: boolean

    TrafficData:
      type: object
      properties:
        views:
          $ref: '#/components/schemas/TrafficStats'
        clones:
          $ref: '#/components/schemas/TrafficStats'
        popularPaths:
          type: array
          items:
            $ref: '#/components/schemas/PopularPath'

    TrafficStats:
      type: object
      properties:
        count:
          type: integer
        uniques:
          type: integer

    PopularPath:
      type: object
      properties:
        path:
          type: string
        title:
          type: string
        count:
          type: integer
        uniques:
          type: integer

    RepositoryOwner:
      type: object
      properties:
        login:
          type: string
        avatarUrl:
          type: string

    DatasetMetadata:
      type: object
      properties:
        generatedAt:
          type: string
          format: date-time
        totalRepositories:
          type: integer
        organizations:
          type: array
          items:
            type: string
        dataCollectionScope:
          type: array
          items:
            type: string
        breakdown:
          $ref: '#/components/schemas/RepositoryBreakdown'
        statistics:
          $ref: '#/components/schemas/GlobalStatistics'

    RepositoryBreakdown:
      type: object
      properties:
        userRepositories:
          type: integer
        organizationRepositories:
          type: object
          additionalProperties:
            type: integer
        privateRepositories:
          type: integer
        publicRepositories:
          type: integer
        forkedRepositories:
          type: integer
        archivedRepositories:
          type: integer
        templateRepositories:
          type: integer

    GlobalStatistics:
      type: object
      properties:
        totalStars:
          type: integer
        totalForks:
          type: integer
        totalWatchers:
          type: integer
        totalIssues:
          type: integer
        totalPullRequests:
          type: integer
        totalReleases:
          type: integer
        totalCommits:
          type: integer
        totalDeployments:
          type: integer
        totalEnvironments:
          type: integer
        totalLanguages:
          type: integer
        averageRepoSize:
          type: integer
        mostUsedLanguages:
          type: array
          items:
            $ref: '#/components/schemas/LanguageStat'
        topTopics:
          type: array
          items:
            $ref: '#/components/schemas/TopicStat'

    LanguageStat:
      type: object
      properties:
        name:
          type: string
        totalSize:
          type: integer
        repoCount:
          type: integer
        percentage:
          type: number

    TopicStat:
      type: object
      properties:
        name:
          type: string
        count:
          type: integer

    RepositoriesAnalytics:
      type: object
      properties:
        totalStats:
          $ref: '#/components/schemas/TotalStats'
        languageAnalytics:
          $ref: '#/components/schemas/LanguageAnalytics'
        topicsAnalytics:
          $ref: '#/components/schemas/TopicsAnalytics'
        devOpsMaturity:
          $ref: '#/components/schemas/DevOpsMaturity'

    TotalStats:
      type: object
      properties:
        totalRepositories:
          type: integer
        totalStars:
          type: integer
        totalForks:
          type: integer
        totalWatchers:
          type: integer
        totalIssues:
          type: integer
        totalPullRequests:
          type: integer
        totalCommits:
          type: integer
        totalReleases:
          type: integer
        totalDeployments:
          type: integer
        repositoriesWithActions:
          type: integer
        repositoriesWithSecurity:
          type: integer
        repositoriesWithPackages:
          type: integer
        repositoriesWithProtection:
          type: integer
        averageCommunityHealth:
          type: integer

    LanguageAnalytics:
      type: object
      properties:
        totalLanguages:
          type: integer
        totalSize:
          type: integer
        languages:
          type: object
          additionalProperties:
            $ref: '#/components/schemas/LanguageStat'
        topLanguages:
          type: array
          items:
            $ref: '#/components/schemas/LanguageStat'

    TopicsAnalytics:
      type: object
      properties:
        totalTopics:
          type: integer
        repositoriesWithTopics:
          type: integer
        topics:
          type: object
          additionalProperties:
            type: integer
        topTopics:
          type: array
          items:
            $ref: '#/components/schemas/TopicStat'

    CollectionMetadata:
      type: object
      properties:
        username:
          type: string
        organizations:
          type: array
          items:
            type: string
        dataSource:
          type: string
        enrichedWithDevOps:
          type: boolean
        includesAnalytics:
          type: boolean
        generatedAt:
          type: string
          format: date-time

    DeveloperSummaryResponse:
      type: object
      properties:
        summary:
          $ref: '#/components/schemas/DeveloperSummary'
        generatedAt:
          type: string
          format: date-time
        computationTime:
          type: number
          description: Temps de calcul en millisecondes
        repositoriesAnalyzed:
          type: integer
          description: Nombre de repositories analysés
        accessLevel:
          type: string
          enum: ["public", "complete"]
          description: Niveau d'accès aux données
        timestamp:
          type: string
          format: date-time

    DeveloperSummary:
      type: object
      properties:
        profile:
          $ref: '#/components/schemas/EnrichedProfile'
        portfolioOverview:
          $ref: '#/components/schemas/PortfolioOverview'
        technologyExpertise:
          $ref: '#/components/schemas/TechnologyExpertise'
        devOpsMaturity:
          $ref: '#/components/schemas/DevOpsMaturity'
        communityImpact:
          $ref: '#/components/schemas/CommunityImpact'
        growthInsights:
          $ref: '#/components/schemas/GrowthInsights'
        recommendations:
          $ref: '#/components/schemas/PersonalizedRecommendations'
        industryBenchmarks:
          $ref: '#/components/schemas/IndustryBenchmarks'
        interfaceMetrics:
          $ref: '#/components/schemas/InterfaceMetrics'
        metadata:
          $ref: '#/components/schemas/SummaryMetadata'

    EnrichedProfile:
      type: object
      properties:
        login:
          type: string
        name:
          type: string
        bio:
          type: string
        location:
          type: string
        company:
          type: string
        blog:
          type: string
        email:
          type: string
        avatarUrl:
          type: string
        reputationScore:
          type: number
          minimum: 0
          maximum: 100
        influenceLevel:
          type: string
          enum: ["Emerging", "Growing", "Influential", "Leader", "Visionary"]
        expertiseAreas:
          type: array
          items:
            type: string
        totalContributions:
          type: integer
        activeYears:
          type: integer
        consistencyScore:
          type: number
          minimum: 0
          maximum: 100
        totalStars:
          type: integer
        totalForks:
          type: integer
        totalWatchers:
          type: integer
        careerLevel:
          type: string
          enum: ["Junior", "Mid-Level", "Senior", "Lead", "Principal", "Staff", "Distinguished"]
        specializations:
          type: array
          items:
            $ref: '#/components/schemas/Specialization'

    PortfolioOverview:
      type: object
      properties:
        totalRepositories:
          type: integer
        publicRepositories:
          type: integer
        privateRepositories:
          type: integer
        contributedRepositories:
          type: integer
        portfolioQualityScore:
          type: number
          minimum: 0
          maximum: 100
        averageStarsPerRepo:
          type: number
        projectDiversityScore:
          type: number
          minimum: 0
          maximum: 100
        totalLanguages:
          type: integer
        
        # NOUVELLES MÉTRIQUES POUR L'INTERFACE
        totalLinesOfCode:
          type: integer
          description: "Total des lignes de code dans tous les repositories"
        organizationBreakdown:
          type: object
          description: "Classification des repositories par type d'organisation"
          properties:
            personal:
              type: integer
              description: "Repositories personnels"
            organization:
              type: integer
              description: "Repositories d'entreprise"
            school:
              type: integer
              description: "Repositories d'établissements scolaires"
        technologyLevels:
          type: object
          description: "Répartition des technologies par niveau de maîtrise"
          properties:
            expert:
              type: integer
              description: "Technologies avec niveau expert (≥80%)"
            advanced:
              type: integer
              description: "Technologies avec niveau avancé (60-79%)"
            operational:
              type: integer
              description: "Technologies avec niveau opérationnel (40-59%)"
        
        primaryLanguages:
          type: array
          items:
            $ref: '#/components/schemas/LanguageUsage'

    TechnologyExpertise:
      type: object
      properties:
        overallExpertiseScore:
          type: number
          minimum: 0
          maximum: 100
        expertLevel:
          type: array
          items:
            $ref: '#/components/schemas/TechnologyMastery'
        advancedLevel:
          type: array
          items:
            $ref: '#/components/schemas/TechnologyMastery'
        intermediateLevel:
          type: array
          items:
            $ref: '#/components/schemas/TechnologyMastery'
        beginnerLevel:
          type: array
          items:
            $ref: '#/components/schemas/TechnologyMastery'

    DevOpsMaturity:
      type: object
      properties:
        devOpsScore:
          type: number
          minimum: 0
          maximum: 100
        maturityLevel:
          type: string
          enum: ["Initial", "Developing", "Defined", "Managed", "Optimizing"]
        cicdAdoption:
          type: number
          minimum: 0
          maximum: 100
        securityMaturity:
          type: number
          minimum: 0
          maximum: 100
        automationScore:
          type: number
          minimum: 0
          maximum: 100

    CommunityImpact:
      type: object
      properties:
        impactScore:
          type: number
          minimum: 0
          maximum: 100
        influenceRadius:
          type: integer
        openSourceContributions:
          type: integer
        maintainedProjects:
          type: integer
        featuredProjects:
          type: array
          items:
            $ref: '#/components/schemas/FeaturedProject'
        achievements:
          type: array
          items:
            $ref: '#/components/schemas/Achievement'

    GrowthInsights:
      type: object
      properties:
        futureGrowthPotential:
          type: number
          minimum: 0
          maximum: 100
        recommendedFocusAreas:
          type: array
          items:
            type: string

    PersonalizedRecommendations:
      type: object
      properties:
        careerRecommendations:
          type: array
          items:
            $ref: '#/components/schemas/CareerRecommendation'
        technologyRecommendations:
          type: array
          items:
            $ref: '#/components/schemas/TechnologyRecommendation'

    IndustryBenchmarks:
      type: object
      properties:
        overallPercentile:
          type: number
          minimum: 0
          maximum: 100
        marketPosition:
          $ref: '#/components/schemas/MarketPosition'

    SummaryMetadata:
      type: object
      properties:
        generatedAt:
          type: string
          format: date-time
        computationTime:
          type: number
        dataCompleteness:
          type: number
          minimum: 0
          maximum: 100
        confidenceScore:
          type: number
          minimum: 0
          maximum: 100

    Specialization:
      type: object
      properties:
        area:
          type: string
        level:
          type: number
          minimum: 0
          maximum: 100
        yearsOfExperience:
          type: integer
        confidence:
          type: number
          minimum: 0
          maximum: 100

    LanguageUsage:
      type: object
      properties:
        name:
          type: string
        proficiencyLevel:
          type: number
          minimum: 0
          maximum: 100
        totalBytes:
          type: integer
        repositoryCount:
          type: integer
        recentUsage:
          type: boolean
        trend:
          type: string
          enum: ["growing", "stable", "declining"]

    TechnologyMastery:
      type: object
      properties:
        technology:
          type: string
        masteryLevel:
          type: number
          minimum: 0
          maximum: 100
        yearsOfExperience:
          type: integer
        projectCount:
          type: integer
        marketDemand:
          type: string
          enum: ["Low", "Medium", "High", "Very High"]

    FeaturedProject:
      type: object
      properties:
        name:
          type: string
        description:
          type: string
        stars:
          type: integer
        significance:
          type: string
        technologies:
          type: array
          items:
            type: string
        impactScore:
          type: number
          minimum: 0
          maximum: 100

    Achievement:
      type: object
      properties:
        title:
          type: string
        description:
          type: string
        category:
          type: string
        rarity:
          type: string
          enum: ["Common", "Uncommon", "Rare", "Epic", "Legendary"]
        unlockedAt:
          type: string
          format: date-time

    CareerRecommendation:
      type: object
      properties:
        type:
          type: string
          enum: ["Role", "Industry", "Skill", "Experience"]
        title:
          type: string
        description:
          type: string
        priority:
          type: string
          enum: ["Low", "Medium", "High", "Critical"]
        effort:
          type: string
          enum: ["Low", "Medium", "High"]
        timeline:
          type: string
        potentialImpact:
          type: number
          minimum: 0
          maximum: 100

    TechnologyRecommendation:
      type: object
      properties:
        technology:
          type: string
        rationale:
          type: string
        currentRelevance:
          type: number
          minimum: 0
          maximum: 100
        futureRelevance:
          type: number
          minimum: 0
          maximum: 100
        learningDifficulty:
          type: string
          enum: ["Easy", "Medium", "Hard", "Expert"]
        marketDemand:
          type: string
          enum: ["Low", "Medium", "High", "Very High"]

    MarketPosition:
      type: object
      properties:
        overallRank:
          type: string
        strengths:
          type: array
          items:
            type: string
        differentiators:
          type: array
          items:
            type: string
        marketValue:
          type: string
          enum: ["Entry", "Junior", "Mid", "Senior", "Lead", "Principal", "Staff"]

    ErrorResponse:
      type: object
      properties:
        success:
          type: boolean
          example: false
        error:
          type: object
          properties:
            type:
              type: string
              example: "VALIDATION_ERROR"
            message:
              type: string
              example: "Données d'entrée invalides"
            details:
              type: object
            timestamp:
              type: string
              format: date-time

    AIAnalysisResponse:
      type: object
      properties:
        message:
          type: string
          example: "Analyse IA lancée avec succès"
        status:
          type: string
          example: "processing"
        analysisId:
          type: string
          example: "abc123"
        estimatedCompletionTime:
          type: string
          format: date-time
        timestamp:
          type: string
          format: date-time

    AIAnalysisResultResponse:
      type: object
      properties:
        message:
          type: string
          example: "Analyse IA récupérée avec succès"
        analysis:
          $ref: '#/components/schemas/AIAnalysisResult'
        insights:
          $ref: '#/components/schemas/AIInsights'
        interfaceMetrics:
          $ref: '#/components/schemas/AIInterfaceMetrics'
        timestamp:
          type: string
          format: date-time

    AIAnalysisResult:
      type: object
      properties:
        qualityScore:
          type: number
          minimum: 0
          maximum: 100
        maintenabilityScore:
          type: number
          minimum: 0
          maximum: 100
        securityScore:
          type: number
          minimum: 0
          maximum: 100
        innovationScore:
          type: number
          minimum: 0
          maximum: 100
        overallHealthScore:
          type: number
          minimum: 0
          maximum: 10
        estimatedVulnerabilities:
          type: integer
        estimatedBugs:
          type: integer
        estimatedBuildTime:
          type: integer
        estimatedTestCoverage:
          type: number
          minimum: 0
          maximum: 100

    AIInsights:
      type: object
      properties:
        summary:
          type: string
        strengths:
          type: array
          items:
            type: string
        recommendations:
          type: array
          items:
            type: string
        careerAdvice:
          type: array
          items:
            type: string

    AIInterfaceMetrics:
      type: object
      properties:
        qualityAverage:
          type: string
        vulnerabilities:
          type: integer
        bugsDetected:
          type: integer
        buildTime:
          type: string
        testCoverage:
          type: number
          minimum: 0
          maximum: 100
        healthScore:
          type: string

    AIServiceStatusResponse:
      type: object
      properties:
        service:
          type: string
          example: "AI Analysis Service"
        status:
          type: string
          example: "available"
        configuration:
          type: object
          properties:
            model:
              type: string
              example: "gpt-4o-mini"
            maxTokens:
              type: integer
              example: 4096
            temperature:
              type: number
              example: 0.3
          required:
            - model
            - maxTokens
            - temperature
        capabilities:
          type: object
          properties:
            qualityAnalysis:
              type: boolean
            securityAnalysis:
              type: boolean
            performanceAnalysis:
              type: boolean
            repositoryScoring:
              type: boolean
            careerInsights:
              type: boolean
          required:
            - qualityAnalysis
            - securityAnalysis
            - performanceAnalysis
            - repositoryScoring
            - careerInsights
        limitations:
          type: array
          items:
            type: string
        fallbackMode:
          type: object
          properties:
            enabled:
              type: boolean
            description:
              type: string
          required:
            - enabled
            - description

    InterfaceMetrics:
      type: object
      description: "Métriques formatées pour l'interface utilisateur - Compatible avec tous les éléments de l'interface demandée"
      properties:
        # Données dashboard principal
        projects:
          type: integer
          description: "Nombre total de projets/repositories"
          example: 133
        commits:
          type: integer
          description: "Nombre total de commits"
          example: 1764
        technologies:
          type: integer
          description: "Nombre de technologies détectées"
          example: 32
        activeProjects:
          type: integer
          description: "Projets actifs (activité < 30 jours)"
          example: 8
        projectsAnalyzed:
          type: integer
          description: "Projets avec métriques complètes"
          example: 133
        
        # Métriques de code
        totalLinesOfCode:
          type: integer
          description: "Total des lignes de code analysées"
          example: 1919842
        totalStars:
          type: integer
          description: "Total des stars reçues"
          example: 11
        totalForks:
          type: integer
          description: "Total des forks"
          example: 45
        
        # Classification par organisation
        organizationBreakdown:
          type: object
          description: "Répartition des projets par type d'organisation"
          properties:
            personal:
              type: object
              properties:
                count:
                  type: integer
                  example: 53
                percentage:
                  type: integer
                  example: 26
            organization:
              type: object
              properties:
                count:
                  type: integer
                  example: 1
                percentage:
                  type: integer
                  example: 16
            school:
              type: object
              properties:
                count:
                  type: integer
                  example: 79
                percentage:
                  type: integer
                  example: 31
        
        # Niveaux de technologies
        technologyLevels:
          type: object
          description: "Répartition des compétences par niveau"
          properties:
            expert:
              type: integer
              description: "Technologies maîtrisées (niveau expert)"
              example: 8
            advanced:
              type: integer
              description: "Technologies confirmées (niveau avancé)"
              example: 2
            operational:
              type: integer
              description: "Technologies opérationnelles (usage régulier)"
              example: 14
        
        # Score moyen calculé
        averageScore:
          type: number
          minimum: 0
          maximum: 100
          description: "Score moyen calculé par IA"
          example: 65.7
        
        # Données repositories individuelles pour l'interface
        topRepositories:
          type: array
          description: "Top repositories avec métadonnées pour l'interface"
          items:
            type: object
            properties:
              name:
                type: string
                example: "portfolio-v2"
              description:
                type: string
                example: "scale with powered red"
              category:
                type: string
                enum: ["Personal", "Organization", "School"]
                example: "Personal"
              stars:
                type: integer
                example: 0
              forks:
                type: integer
                example: 0
              languages:
                type: array
                items:
                  type: string
                example: ["TypeScript", "JavaScript", "CSS"]
              lastUpdate:
                type: string
                format: date-time
                example: "2025-07-16T00:00:00Z"
              source:
                type: string
                example: "GitHub"

tags:
  - name: System
    description: Endpoints système (santé, connectivité)
  - name: Authentication
    description: Authentification et gestion des sessions
  - name: Users
    description: Gestion des utilisateurs et profils GitHub complets
  - name: Repositories
    description: Gestion des repositories avec analyses DevOps complètes
  - name: Summary
    description: Analytics ultra-complets pour portfolios, CV et intégrations professionnelles
  - name: AI Analysis
    description: Analyse avancée et intelligence artificielle

externalDocs:
  description: Documentation complète de l'API
  url: https://docs.gh-insight-engine.com 