# Template pour .env.test
# Copiez ce fichier vers .env.test et remplissez avec vos vraies valeurs

# Configuration pour les tests d'intégration réels
# Ces variables doivent être définies avec de vraies valeurs GitHub

# Base de données de test (MongoDB en mémoire)
DATABASE_URL=mongodb://localhost:27017/github_insight_engine_test

# Authentification GitHub (REQUIS - Valeurs réelles)
GH_TOKEN=your_github_classic_token_here
GITHUB_USERNAME=your_github_username_here
GITHUB_FULL_NAME=Your Full Name Here

# OpenAI (pour les tests d'insights IA)
OPENAI_API_KEY=your_openai_api_key_here

# Configuration serveur de test
PORT=3001
NODE_ENV=test

# JWT pour authentification API
JWT_SECRET=test-jwt-secret-key-for-integration-tests

# Rate limiting (plus permissif pour les tests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Configuration des timeouts pour les tests
TEST_TIMEOUT=60000
API_TIMEOUT=30000

# Log level pour les tests
LOG_LEVEL=info 